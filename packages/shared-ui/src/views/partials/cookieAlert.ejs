<!-- Cookie Alert -->
<div class="container mt-3">
    <div class="row">
    <div class="col">
        <div id="cookieAlert" class="alert alert-danger alert-dismissible fade show position-relative" role="alert">
        This site uses essential cookies for functionality. By continuing to use our site, you agree to their use. 
        <br>
        <a href="<%= typeof cookiePolicyUrl !== 'undefined' ? cookiePolicyUrl : '/policy/cookie-policy' %>">Cookie Policy</a>
        <button id="cookieAlertBtn" type="button" class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-2" data-bs-dismiss="alert" aria-label="Accept cookies">
            <i class="fa-regular fa-thumbs-up"></i>
        </button>
        </div>
    </div>
    </div>
</div>
