<% layout('layouts/boilerplate') %>

<% contentTitle = 'Blocked IPs' %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-ban me-2"></i>Blocked IP Addresses</h1>
</div>

<div class="alert alert-info">
    <i class="fas fa-info-circle me-2"></i>
    IP addresses blocked here will be blocked across <strong>ALL</strong> tracked applications (blog, slapp, quiz, landing).
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5><i class="fas fa-plus-circle me-2"></i>Block New IP Address</h5>
    </div>
    <div class="card-body">
        <form method="POST" action="/admin/block-ip" class="row g-3">
            <div class="col-md-8">
                <label for="ip" class="form-label">IP Address</label>
                <input type="text" class="form-control" id="ip" name="ip" placeholder="e.g., 192.168.1.100" required>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-danger w-100">
                    <i class="fas fa-ban me-2"></i>Block IP
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5><i class="fas fa-list me-2"></i>Currently Blocked IPs (<%= blockedIPs.length %>)</h5>
    </div>
    <div class="card-body">
        <% if (blockedIPs && blockedIPs.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>IP Address</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% blockedIPs.forEach(function(ip) { %>
                            <tr>
                                <td><code><%= ip %></code></td>
                                <td>
                                    <form method="POST" action="/admin/unblock-ip" style="display: inline;">
                                        <input type="hidden" name="origIP" value="<%= ip %>">
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="fas fa-check me-1"></i>Unblock
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-4">
                <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                <h5>No Blocked IPs</h5>
                <p class="text-muted">All IPs are currently allowed access.</p>
            </div>
        <% } %>
    </div>
</div>
