<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="MY IRONMAN BLOG - From start to finish, follow my journey." />
    <meta property="og:description" content="A blog about my Ironman triathlon journey. Follow me from my first day of training to the big day. I discuss nutrition, training plans, triathlon kit and ups and downs." />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="MY IRONMAN BLOG - From start to finish, follow my journey." />
    <meta property="twitter:description" content="A blog about my Ironman triathlon journey. Follow me from my first day of training to the big day. I discuss nutrition, training plans, triathlon kit and ups and downs." />
    
    <meta
      name="title"
      content="MY IRONMAN BLOG - From start to finish, follow my journey."
    />
    <meta
      name="description"
      content="A blog about my Ironman triathlon journey. Follow me from my first day of training to the big day. I discuss nutrition, training plans, triathlon kit and ups and downs."
    />
    <meta
      name="keywords"
      content="Ironman, Ironman Blog, training plan, triathlon, journey, nutrition, cycling, swim, run, shopping list"
    />
    <meta name="author" content="Chris Hutchinson" />
    <meta name="robots" content="index, follow" />
    <title><%= title %></title>

    <!-- Favicon -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />

    <!-- Mainfest -->
    <link rel="manifest" href="/manifest/manifest.json" />

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />

    <!-- Font Aewsome -->
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css"
    />

    <!-- Personal CSS -->
    <% if (typeof css_page !== 'undefined') { %>
      <link
        rel="stylesheet"
        type="text/css"
        href="/stylesheets/<%= css_page %>.css"
      />
    <% } %>
    
    <link
      rel="stylesheet"
      type="text/css"
      href="/stylesheets/boilerplate.css"
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Yanone+Kaffeesatz&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="d-flex flex-column vh-100">
    
    <%- include('../partials/navbar')%>

    <!-- Cookie Alert -->
    <div class="container mt-3">
      <div class="row">
        <div class="col">
          <div id="cookieAlert" class="alert alert-danger alert-dismissible fade show position-relative" role="alert">
            This site uses essential cookies for functionality. By continuing to use our site, you agree to their use. 
            <br>
            <a href="/policy/cookie-policy">Cookie Policy</a>
            <button id="cookieAlertBtn" type="button" class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-2" aria-label="Accept cookies">
                <i class="fa-regular fa-thumbs-up"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <main class="container mt-3">
      <%- include('../partials/flash') %> 
      <%- body %>
    </main>

    <%- include('../partials/footer')%>

    <!-- Bootstrap scripts -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>

    <!-- Personal js -->
    <% if (typeof js_page !== 'undefined') { %>
      <script type="text/javascript" src="/javascripts/<%= js_page %>.js"></script>
    <% } %>
    <script type="text/javascript" src="/javascripts/boilerplate.js"></script>
    <script type="text/javascript" src="/javascripts/validateForms.js"></script>

  </body>
</html>
