<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="longrunner.co.uk landing page" />
    <meta property="og:description" content="longrunner.co.uk is a landing page that links to the longrunner app ecosystem, including the shopping list app, quiz app, and blog app" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="longrunner.co.uk landing page" />
    <meta property="twitter:description" content="longrunner.co.uk is a landing page that links to the longrunner app ecosystem, including the shopping list app, quiz app, and blog app" />
    
    <meta
      name="title"
      content="longrunner.co.uk landing page"
    />
    <meta
      name="description"
      content="longrunner.co.uk is a landing page that links to the longrunner app ecosystem, including the shopping list app, quiz app, and blog app"
    />
    <meta
      name="keywords"
      content="Landing, Navigation, slapp, quiz, blog"
    />
    <meta name="author" content="Chris Hutchinson" />
    <meta name="robots" content="index, follow" />
    <title><%= title %></title>

    <!-- Favicon -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />

    <!-- Bootstrap CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css"
      integrity="sha384-TX8t27EcRE3e/ihU7zmQxVncDAy5uIKz4rEkgIXeMed4M0jlfIDPvg6uqKI2xXr2"
      crossorigin="anonymous"
    />

    <!-- Font Aewsome -->
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css"
    />

    <!-- Personal CSS -->
    <% if (typeof css_page !== 'undefined') { %>
      <link
        rel="stylesheet"
        type="text/css"
        href="/stylesheets/<%= css_page %>.css"
      />
    <% } %>
    <link
      rel="stylesheet"
      type="text/css"
      href="/stylesheets/boilerplate.css"
    />


    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Yanone+Kaffeesatz&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="d-flex flex-column vh-100">

    <%- include('../partials/navbar')%>

    <!-- Cookie Alert -->
    <div class="container mt-3">
      <div class="row">
        <div class="col">
          <div id="cookieAlert" class="alert alert-danger alert-dismissible fade show" role="alert">
            This site uses essential cookies for functionality. By continuing to use our site, you agree to their use. 
            <br>
            <a href="/policy/cookie-policy">Cookie Policy</a>
            <button id="cookieAlertBtn" type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true"><i class="fa-regular fa-thumbs-up"></i></i></i></span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <main class="container mt-3 pb-5">
      <div class="pb-3">
        <%- include('../partials/flash') %>
        <%- body %>
      </div>

    </main>

    <!-- BootStrap scripts -->
    <script
      src="https://code.jquery.com/jquery-3.5.1.slim.min.js"
      integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-ho+j7jyWK8fNQe+A12Hb8AhRq26LrZ/JpcUGGOn+Y7RsweNrtN/tE3MoK7ZeZDyx"
      crossorigin="anonymous"
    ></script>

    <!-- Boilerplate script -->
    <script type="text/javascript" src="/javascripts/boilerplate.js "></script>
    <!-- Personal js -->
    <% if (typeof js_page !== 'undefined') { %>
      <script type="text/javascript" src="/javascripts/<%= js_page %>.js"></script>
    <% } %>

  </body>
</html>
